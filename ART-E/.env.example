# OpenAI API Key（RULER評価のジャッジモデル用）
OPENAI_API_KEY=your_openai_api_key_here

# Weights & Biases API Key（トレーニング・推論・ログ用）
WANDB_API_KEY=your_wandb_api_key_here

# W&B Entity名（チーム名または個人ユーザー名）
WANDB_ENTITY=your_entity_here

# W&B プロジェクト名（省略時: ARTE-Email-Search-Agent）
# WANDB_PROJECT=ARTE-Email-Search-Agent

# W&B Dedicated Cloud / オンプレミスの場合のみ設定
# WANDB_BASE_URL=https://wandb.your-company.com
